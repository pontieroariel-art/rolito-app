rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Lee el rol del usuario autenticado desde su propio documento
    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol;
    }

    // Usuarios con acceso de gestión
    function isManager() {
      return myRole() in ['super_admin', 'comercial'];
    }

    // Usuarios con acceso operativo (pedidos y logística)
    function isOperator() {
      return myRole() in ['super_admin', 'logistica'];
    }

    // ── Colección de usuarios ──────────────────────────────────────────────
    match /users/{userId} {
      // Cada usuario puede leer y escribir su propio documento
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // super_admin y comercial pueden leer y modificar todos los usuarios
      allow read, write: if request.auth != null && isManager();
    }

    // ── Pedidos ────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Cualquier usuario autenticado puede crear pedidos
      allow create: if request.auth != null;

      // Lectura: el cliente dueño, el chofer asignado, o un operador
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.clientId ||
        request.auth.token.email == resource.data.driverId ||
        isOperator()
      );

      // Escritura: el chofer asignado (para marcar entregado) o un operador
      allow update, delete: if request.auth != null && (
        request.auth.token.email == resource.data.driverId ||
        isOperator()
      );
    }

    // ── Configuración (lista de choferes, etc.) ───────────────────────────
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isOperator();
    }

    // ── Emails de notificación admin ──────────────────────────────────────────
    // Lectura: cualquier usuario autenticado (el cliente necesita los emails al crear un pedido)
    // Escritura: solo operadores
    match /configuracion/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isOperator();
    }

    // ── Ubicaciones en tiempo real (GPS del chofer) ────────────────────────
    // El documento ID es el email del chofer
    match /ubicaciones/{driverEmail} {
      allow write: if request.auth != null && request.auth.token.email == driverEmail;
      allow read:  if request.auth != null;
    }
  }
}
