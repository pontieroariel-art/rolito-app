rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Lee el rol del usuario autenticado desde su propio documento.
    // Usa exists() antes de get() para no fallar si el doc aún no existe.
    // Soporta campo nuevo 'rol' y campo viejo 'role' por compatibilidad.
    function myRole() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      let data = exists(path) ? get(path).data : {};
      return data.get('rol', data.get('role', 'none'));
    }

    // Lee el estado ('activo'/'inactivo'/'pendiente') del usuario autenticado.
    function myEstado() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      let data = exists(path) ? get(path).data : {};
      return data.get('estado', 'none');
    }

    // Gerente comercial: acuerdos de precios y activación de clientes
    function isGerenteComercial() {
      return myRole() == 'gerente_comercial';
    }

    // Gerente general: visibilidad total + aprobación de clientes (sin operación)
    function isGerenteGeneral() {
      return myRole() == 'gerente_general';
    }

    // Usuarios con acceso de gestión
    function isManager() {
      return myRole() in ['super_admin', 'gerente_comercial', 'comercial'];
    }

    // Usuarios con acceso operativo (pedidos y logística)
    function isOperator() {
      return myRole() in ['super_admin', 'logistica'];
    }

    // Facturación: solo lectura sobre pedidos y clientes
    function isFacturacion() {
      return myRole() == 'facturacion';
    }

    // Cualquier rol de staff (todo lo que no sea cliente).
    function isStaff() {
      return myRole() != 'cliente' && myRole() != 'none';
    }

    // ── Colección de usuarios ──────────────────────────────────────────────
    match /users/{userId} {
      function isSelf() { return request.auth != null && request.auth.uid == userId; }

      // Campos privilegiados que un no-super_admin NO puede alterar sobre un
      // documento existente. Se comparan con get() para tolerar campos ausentes.
      function rolUnchanged()    { return request.resource.data.rol == resource.data.rol; }
      function estadoUnchanged() { return request.resource.data.estado == resource.data.estado; }
      function preciosUnchanged() {
        return request.resource.data.get('listaPreciosId', '') == resource.data.get('listaPreciosId', '')
            && request.resource.data.get('preciosCustom', {}) == resource.data.get('preciosCustom', {});
      }
      // Campos de identidad / internos que el cliente NO puede alterar sobre su
      // propio documento (sí pueden hacerlo managers/logística).
      function identidadUnchanged() {
        return request.resource.data.get('cuit', '')           == resource.data.get('cuit', '')
            && request.resource.data.get('codigoCliente', '')  == resource.data.get('codigoCliente', '')
            && request.resource.data.get('codVendedor', '')    == resource.data.get('codVendedor', '')
            && request.resource.data.get('sector', '')         == resource.data.get('sector', '')
            && request.resource.data.get('creadoPor', null)    == resource.data.get('creadoPor', null);
      }

      // El documento objetivo es un CLIENTE (no otro staff ni un super_admin).
      // Cierra el lockout de admin y la edición cruzada de cuentas de personal:
      // las ramas de staff de abajo SOLO aplican sobre users con rol 'cliente'.
      function targetEsCliente() {
        return resource.data.get('rol', 'cliente') == 'cliente';
      }

      // Campos que el staff (comercial/gerente_comercial/logistica) puede editar
      // sobre un cliente. Excluye identidad (cuit, codigoCliente, codVendedor,
      // sector), credenciales/login (email, dni, username) y rol.
      function camposGestionClienteOk() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'razonSocial', 'nombreContacto', 'nombre', 'telefono',
          'estado', 'fechaAprobacion', 'aprobadoPor',
          'listaPreciosId', 'preciosCustom', 'vigenciaCustom', 'ultimoCambioPrecio',
          'esVisita', 'frecuenciaVisita',
          'addresses', 'lat', 'lng', 'coordPendiente',
          'notasContacto',
        ]);
      }

      // ── Lectura ──
      allow read: if isSelf();
      allow read: if request.auth != null
        && (isManager() || myRole() == 'logistica' || isFacturacion() || isGerenteGeneral());

      // ── super_admin: control total (asigna roles, crea staff, limpia datos) ──
      allow read, write: if request.auth != null && myRole() == 'super_admin';

      // ── Alta del propio documento ──
      // Registro público: el usuario SOLO puede crearse como 'cliente'.
      // El alta de staff la escribe un super_admin (regla de arriba) y la de
      // choferes un operador (regla siguiente); nunca el propio usuario nuevo.
      allow create: if isSelf() && request.resource.data.rol == 'cliente';

      // Operadores (super_admin/logistica) pueden dar de alta choferes.
      allow create: if request.auth != null && isOperator()
        && request.resource.data.rol == 'chofer';

      // ── Edición del propio perfil: NO puede tocar rol / estado / precios / identidad ──
      allow update: if isSelf() && rolUnchanged() && estadoUnchanged()
        && preciosUnchanged() && identidadUnchanged();

      // ── gerente_comercial / comercial / logistica: gestión de clientes ──
      // Solo sobre documentos de CLIENTE y solo los campos de gestión (nunca
      // identidad, login ni rol). Antes estas ramas permitían editar cualquier
      // documento —incluido el de un super_admin— con cualquier campo salvo rol.
      allow update: if request.auth != null
        && myRole() in ['gerente_comercial', 'comercial', 'logistica']
        && targetEsCliente()
        && camposGestionClienteOk();

      // ── gerente_general: aprobar/rechazar clientes (solo estado, solo clientes) ──
      allow update: if request.auth != null && isGerenteGeneral()
        && targetEsCliente()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['estado', 'fechaAprobacion', 'aprobadoPor']);

      // ── facturacion: asignar código interno de facturación (solo ese campo) ──
      allow update: if request.auth != null && isFacturacion()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['codigoCliente']);
    }

    // ── Pedidos ────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // El cliente solo puede crear pedidos pendientes para sí mismo
      // El staff puede crear pedidos para cualquier cliente en cualquier estado
      allow create: if request.auth != null && (
        (
          request.resource.data.clientId == request.auth.uid
          && request.resource.data.status == 'pendiente'
          // Solo un cliente activo puede crear pedidos (bloquea a pendientes/
          // inactivos y a roles no-cliente que también cumplirían clientId==uid).
          && myRole() == 'cliente'
          && myEstado() == 'activo'
          // El cliente no puede autoasignarse un chofer al crear.
          && request.resource.data.get('driverId', null) == null
          // Ni fabricar campos que son solo de staff (PDF, reprogramación,
          // entrega, OC, historial de acciones, etc.).
          && !request.resource.data.keys().hasAny([
               'origenPdf', 'origenManual', 'origenRecurrente', 'historialAcciones',
               'reprogramado', 'reasignado', 'fechaOriginal', 'motivoReprogramacion',
               'choferOriginal', 'motivoReasignacion', 'entregaParcial',
               'productosEntregados', 'notaEntrega', 'numeroOC', 'fechaEmision',
               'fechaTope', 'motivoCancelacion'
             ])
        ) ||
        isOperator() ||
        isManager()
      );

      // Lectura: el cliente dueño, el chofer asignado, operador, comercial, facturación o gerente general
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.clientId ||
        request.auth.token.email == resource.data.driverId ||
        isOperator() ||
        isManager() ||
        isFacturacion() ||
        isGerenteGeneral()
      );

      // Actualización del chofer asignado: solo para marcar la entrega. Nunca
      // precio/productos/cliente/chofer (antes esta rama no tenía ningún
      // límite de campos y compartía allow con isOperator()/isGerenteComercial()).
      allow update: if request.auth != null &&
        request.auth.token.email == resource.data.driverId &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'productosEntregados', 'entregaParcial', 'notaEntrega', 'updatedAt']);

      // Actualización por operador o gerente_comercial: gestión operativa
      // completa del pedido (estado, chofer, reprogramación, edición de
      // productos/fecha desde el kanban), pero nunca los campos de identidad
      // del cliente ni los de auditoría de creación.
      allow update: if request.auth != null && (isOperator() || isGerenteComercial())
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly([
               'status', 'updatedAt', 'motivoCancelacion', 'historialAcciones',
               'driverId', 'clientAddress', 'date', 'reprogramado', 'fechaOriginal',
               'motivoReprogramacion', 'choferOriginal', 'reasignado',
               'motivoReasignacion', 'products', 'horaEntrega', 'notes', 'numeroOC'
             ]);

      // gerente_general: reprogramar/reasignar desde /admin/monitoreo.
      // Solo los campos de esas dos acciones; no puede reescribir el pedido.
      allow update: if request.auth != null && isGerenteGeneral()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly([
               'date', 'driverId', 'status', 'updatedAt',
               'reprogramado', 'fechaOriginal', 'motivoReprogramacion',
               'reasignado', 'choferOriginal', 'motivoReasignacion'
             ]);

      // Borrado: solo operadores (herramienta de limpieza). El chofer no borra.
      allow delete: if request.auth != null && isOperator();

      // El cliente puede cancelar su propio pedido solo si está pendiente, y esa
      // operación solo puede tocar el estado/motivo (no reescribir el pedido).
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.clientId &&
        resource.data.status == 'pendiente' &&
        request.resource.data.status == 'cancelado' &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'motivoCancelacion', 'updatedAt']);
    }

    // ── Configuración (catálogo, zonas prohibidas, etc.) ──────────────────────
    match /config/{docId} {
      // El catálogo lo necesita el cliente para armar el pedido; el resto
      // (zonas prohibidas, etc.) es operativo → solo staff.
      allow read: if request.auth != null && (docId == 'catalogo' || isStaff());
      allow write: if request.auth != null && isOperator();
      // Comercial y gerente_comercial pueden editar el catálogo (config/catalogo).
      allow write: if request.auth != null && docId == 'catalogo' && isManager();
    }

    // ── Emails de notificación admin ──────────────────────────────────────────
    // Contiene emails de staff, modoTest y testEmail → nunca legible por el
    // cliente. Los triggers de email lo leen server-side (admin SDK), no la UI.
    // Escritura: solo operadores.
    match /configuracion/{docId} {
      allow read:  if request.auth != null && isStaff();
      allow write: if request.auth != null && isOperator();
    }

    // ── Listas de precios ─────────────────────────────────────────────────────
    // Lectura: cualquier usuario autenticado (el cliente necesita su lista al pedir)
    // Escritura: operadores (super_admin/logistica) y managers (comercial/gerente_comercial)
    match /listas-precios/{listaId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && (isOperator() || isManager());
    }

    // ── Catálogo de productos ─────────────────────────────────────────────────
    match /catalogo/{productoId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isOperator();
    }

    // ── Visitas programadas ───────────────────────────────────────────────────
    match /programas-visita/{id} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isOperator();
    }
    match /visitas-puntuales/{id} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isOperator();
      // Chofer puede actualizar sus propias visitas, solo el estado/notas/orderId
      // (no reasignarse ni reescribir la visita).
      allow update: if request.auth != null
        && myRole() == 'chofer'
        && resource.data.driverId == request.auth.token.email
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'notas', 'orderId']);
    }

    // ── Flota de vehículos ────────────────────────────────────────────────────
    match /flota/{camionId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isOperator();
    }

    // ── Pedidos recurrentes ───────────────────────────────────────────────────
    // El documento ID es el clientId. El cliente gestiona el suyo; operadores leen todos.
    match /pedidos-recurrentes/{clientId} {
      allow read, write: if request.auth != null && request.auth.uid == clientId
        && (!request.resource.data.keys().hasAny(['clientId']) || request.resource.data.clientId == request.auth.uid);
      allow read, write: if request.auth != null && isOperator();
    }

    // ── Índices de login (lectura pública — solo mapean usuario/CUIT → email)
    // La lectura debe ser pública: el login por CUIT/DNI resuelve el email
    // ANTES de autenticar. La contraseña sigue siendo requerida para autenticar.
    match /cuitIndex/{cuit} {
      allow read:  if true;
      // Un cliente solo puede CREAR (nunca sobrescribir) el índice de SU
      // PROPIO CUIT, apuntando a su propio email — evita que un usuario
      // secuestre/envenene el índice de un CUIT ya asignado a otra cuenta.
      // Operadores y managers pueden escribir cualquiera en cualquier momento
      // (alta manual / importación / corrección).
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly(['email'])
        && request.resource.data.email is string
        && (
          (!exists(/databases/$(database)/documents/cuitIndex/$(cuit))
            && request.resource.data.email == request.auth.token.email)
          || isManager() || isOperator()
        );
    }

    match /choferIndex/{username} {
      allow read:  if true;
      allow write: if request.auth != null && isOperator();
    }

    match /staffIndex/{username} {
      allow read:  if true;
      allow write: if request.auth != null && myRole() == 'super_admin';
    }

    match /dniIndex/{dni} {
      allow read:  if true;
      allow write: if request.auth != null && isOperator();
    }

    match /staffDniIndex/{dni} {
      allow read:  if true;
      allow write: if request.auth != null && myRole() == 'super_admin';
    }

    // ── Historial de precios ──────────────────────────────────────────────────
    match /historialPrecios/{eventoId} {
      allow read:   if request.auth != null && (isManager() || isOperator() || isFacturacion() || isGerenteGeneral());
      allow create: if request.auth != null && (isManager() || isOperator());
      allow update, delete: if false;
    }

    // ── Despachos ─────────────────────────────────────────────────────────────
    match /despachos/{despachoId} {
      allow read: if request.auth != null && (
        isOperator() ||
        isGerenteGeneral() ||
        request.auth.token.email == resource.data.driverId
      );
      allow write: if request.auth != null && isOperator();
    }

    // ── Asignaciones diarias (camión + ayudante por chofer y fecha) ──────────
    // El documento ID es la fecha 'yyyy-MM-dd'
    match /asignacionesDia/{fecha} {
      allow read:  if request.auth != null && (isOperator() || isGerenteGeneral());
      allow write: if request.auth != null && isOperator();
    }

    // ── Ubicaciones en tiempo real (GPS del chofer) ────────────────────────
    // El documento ID es el email del chofer
    match /ubicaciones/{driverEmail} {
      allow write: if request.auth != null && (
        request.auth.token.email == driverEmail || isOperator()
      );
      // Lectura: staff que ve el mapa en vivo (operadores, managers, gerente
      // general) y el propio chofer. El CLIENTE ya no lee esta colección: su
      // seguimiento del camión se resuelve server-side (trigger
      // mirrorDriverLocation espeja la posición dentro de su propio pedido),
      // para no exponerle la ubicación ni el teléfono de toda la flota.
      allow read: if request.auth != null && (
        isOperator() || isManager() || isGerenteGeneral() ||
        request.auth.token.email == driverEmail
      );
    }
  }
}
