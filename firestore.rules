rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Lee el rol del usuario autenticado desde su propio documento.
    // Usa exists() antes de get() para no fallar si el doc aún no existe.
    // Soporta campo nuevo 'rol' y campo viejo 'role' por compatibilidad.
    function myRole() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      let data = exists(path) ? get(path).data : {};
      return data.get('rol', data.get('role', 'none'));
    }

    // Gerente comercial: acuerdos de precios y activación de clientes
    function isGerenteComercial() {
      return myRole() == 'gerente_comercial';
    }

    // Gerente general: visibilidad total + aprobación de clientes (sin operación)
    function isGerenteGeneral() {
      return myRole() == 'gerente_general';
    }

    // Usuarios con acceso de gestión
    function isManager() {
      return myRole() in ['super_admin', 'gerente_comercial', 'comercial'];
    }

    // Usuarios con acceso operativo (pedidos y logística)
    function isOperator() {
      return myRole() in ['super_admin', 'logistica'];
    }

    // Facturación: solo lectura sobre pedidos y clientes
    function isFacturacion() {
      return myRole() == 'facturacion';
    }

    // ── Colección de usuarios ──────────────────────────────────────────────
    match /users/{userId} {
      function isSelf() { return request.auth != null && request.auth.uid == userId; }

      // Campos privilegiados que un no-super_admin NO puede alterar sobre un
      // documento existente. Se comparan con get() para tolerar campos ausentes.
      function rolUnchanged()    { return request.resource.data.rol == resource.data.rol; }
      function estadoUnchanged() { return request.resource.data.estado == resource.data.estado; }
      function preciosUnchanged() {
        return request.resource.data.get('listaPreciosId', '') == resource.data.get('listaPreciosId', '')
            && request.resource.data.get('preciosCustom', {}) == resource.data.get('preciosCustom', {});
      }

      // ── Lectura ──
      allow read: if isSelf();
      allow read: if request.auth != null
        && (isManager() || myRole() == 'logistica' || isFacturacion() || isGerenteGeneral());

      // ── super_admin: control total (asigna roles, crea staff, limpia datos) ──
      allow read, write: if request.auth != null && myRole() == 'super_admin';

      // ── Alta del propio documento ──
      // Registro público: el usuario SOLO puede crearse como 'cliente'.
      // El alta de staff la escribe un super_admin (regla de arriba) y la de
      // choferes un operador (regla siguiente); nunca el propio usuario nuevo.
      allow create: if isSelf() && request.resource.data.rol == 'cliente';

      // Operadores (super_admin/logistica) pueden dar de alta choferes.
      allow create: if request.auth != null && isOperator()
        && request.resource.data.rol == 'chofer';

      // ── Edición del propio perfil: NO puede tocar rol / estado / precios ──
      allow update: if isSelf() && rolUnchanged() && estadoUnchanged() && preciosUnchanged();

      // ── gerente_comercial y comercial: gestión de clientes y precios (no roles) ──
      allow update: if request.auth != null
        && myRole() in ['gerente_comercial', 'comercial'] && rolUnchanged();

      // ── logistica: editar clientes y domicilios (no roles) ──
      allow update: if request.auth != null && myRole() == 'logistica' && rolUnchanged();

      // ── gerente_general: aprobar/rechazar clientes (solo estado) ──
      allow update: if request.auth != null && isGerenteGeneral()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['estado', 'fechaAprobacion', 'aprobadoPor']);
    }

    // ── Pedidos ────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // El cliente solo puede crear pedidos pendientes para sí mismo
      // El staff puede crear pedidos para cualquier cliente en cualquier estado
      allow create: if request.auth != null && (
        (request.resource.data.clientId == request.auth.uid && request.resource.data.status == 'pendiente') ||
        isOperator() ||
        isManager()
      );

      // Lectura: el cliente dueño, el chofer asignado, operador, comercial, facturación o gerente general
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.clientId ||
        request.auth.token.email == resource.data.driverId ||
        isOperator() ||
        isManager() ||
        isFacturacion() ||
        isGerenteGeneral()
      );

      // Actualización: el chofer asignado (para marcar entregado) o un operador
      allow update: if request.auth != null && (
        request.auth.token.email == resource.data.driverId ||
        isOperator()
      );

      // Borrado: solo operadores (herramienta de limpieza). El chofer no borra.
      allow delete: if request.auth != null && isOperator();

      // El cliente puede cancelar su propio pedido solo si está pendiente
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.clientId &&
        resource.data.status == 'pendiente' &&
        request.resource.data.status == 'cancelado';
    }

    // ── Configuración (lista de choferes, etc.) ───────────────────────────
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isOperator();
    }

    // ── Emails de notificación admin ──────────────────────────────────────────
    // Lectura: cualquier usuario autenticado (el cliente necesita los emails al crear un pedido)
    // Escritura: solo operadores
    match /configuracion/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isOperator();
    }

    // ── Listas de precios ─────────────────────────────────────────────────────
    // Lectura: cualquier usuario autenticado (el cliente necesita su lista al pedir)
    // Escritura: solo operadores
    match /listas-precios/{listaId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isOperator();
    }

    // ── Catálogo de productos ─────────────────────────────────────────────────
    match /catalogo/{productoId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isOperator();
    }

    // ── Visitas programadas ───────────────────────────────────────────────────
    match /programas-visita/{id} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isOperator();
    }
    match /visitas-puntuales/{id} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isOperator();
      // Chofer puede actualizar sus propias visitas (marcar sin_contacto, etc.)
      allow update: if request.auth != null
        && myRole() == 'chofer'
        && resource.data.driverId == request.auth.token.email;
    }

    // ── Flota de vehículos ────────────────────────────────────────────────────
    match /flota/{camionId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isOperator();
    }

    // ── Pedidos recurrentes ───────────────────────────────────────────────────
    // El documento ID es el clientId. El cliente gestiona el suyo; operadores leen todos.
    match /pedidos-recurrentes/{clientId} {
      allow read, write: if request.auth != null && request.auth.uid == clientId
        && (!request.resource.data.keys().hasAny(['clientId']) || request.resource.data.clientId == request.auth.uid);
      allow read, write: if request.auth != null && isOperator();
    }

    // ── Índices de login (lectura pública — solo mapean usuario/CUIT → email)
    // La lectura debe ser pública: el login por CUIT/DNI resuelve el email
    // ANTES de autenticar. La contraseña sigue siendo requerida para autenticar.
    match /cuitIndex/{cuit} {
      allow read:  if true;
      // Un cliente solo puede apuntar un CUIT a SU PROPIO email (evita que un
      // usuario redirija el índice de otro a un email arbitrario). Operadores
      // y managers pueden escribir cualquiera (alta manual / importación).
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly(['email'])
        && request.resource.data.email is string
        && (
          request.resource.data.email == request.auth.token.email
          || isManager() || isOperator()
        );
    }

    match /choferIndex/{username} {
      allow read:  if true;
      allow write: if request.auth != null && isOperator();
    }

    match /staffIndex/{username} {
      allow read:  if true;
      allow write: if request.auth != null && myRole() == 'super_admin';
    }

    match /dniIndex/{dni} {
      allow read:  if true;
      allow write: if request.auth != null && isOperator();
    }

    match /staffDniIndex/{dni} {
      allow read:  if true;
      allow write: if request.auth != null && myRole() == 'super_admin';
    }

    // ── Historial de precios ──────────────────────────────────────────────────
    match /historialPrecios/{eventoId} {
      allow read:   if request.auth != null && (isManager() || isOperator() || isFacturacion() || isGerenteGeneral());
      allow create: if request.auth != null && (isManager() || isOperator());
      allow update, delete: if false;
    }

    // ── Despachos ─────────────────────────────────────────────────────────────
    match /despachos/{despachoId} {
      allow read: if request.auth != null && (
        isOperator() ||
        isGerenteGeneral() ||
        request.auth.token.email == resource.data.driverId
      );
      allow write: if request.auth != null && isOperator();
    }

    // ── Asignaciones diarias (camión + ayudante por chofer y fecha) ──────────
    // El documento ID es la fecha 'yyyy-MM-dd'
    match /asignacionesDia/{fecha} {
      allow read:  if request.auth != null && (isOperator() || isGerenteGeneral());
      allow write: if request.auth != null && isOperator();
    }

    // ── Ubicaciones en tiempo real (GPS del chofer) ────────────────────────
    // El documento ID es el email del chofer
    match /ubicaciones/{driverEmail} {
      allow write: if request.auth != null && (
        request.auth.token.email == driverEmail || isOperator()
      );
      allow read:  if request.auth != null;
    }
  }
}
