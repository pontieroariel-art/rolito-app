# Copiá este archivo como .env y completá los valores

# API Key de Resend (resend.com → API Keys)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Email remitente
# Para pruebas: onboarding@resend.dev (no requiere verificación de dominio)
# Para producción: pedidos@rolito.com.ar (requiere verificar el dominio en Resend)
FROM_EMAIL=onboarding@resend.dev

# URL de la app (para links en los emails)
APP_URL=https://rolito-app.vercel.app
