# ─── Firebase ────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Google Maps ─────────────────────────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=

# ─── Push notifications (VAPID — clave pública) ──────────────────────────────
VITE_VAPID_PUBLIC_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Secretos de Cloud Functions (NO van acá — no son variables de cliente).
# Se configuran con: firebase functions:secrets:set <NOMBRE>
#   RESEND_API_KEY      — envío de emails (Resend)
#   VAPID_PUBLIC_KEY    — web push (servidor)
#   VAPID_PRIVATE_KEY   — web push (servidor)
#   ORS_KEY             — OpenRouteService (ruteo del despacho, server-side)
# ─────────────────────────────────────────────────────────────────────────────
